{
  "name": "procedural-chip-texture",
  "version": "0.1.0",
  "description": "Procedural IC chip texture visualization — deterministic floorplan, routing, and thin-film interference rendered to canvas.",
  "type": "module",
  "scripts": {
    "prebuild": "bash ./scripts/bust.sh",
    "predev": "bash ./scripts/bust.sh || true",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 4173",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-plugin-pwa": "^0.21.1"
  },
  "dependencies": {
    "simplex-noise": "^4.0.3"
  }
}
